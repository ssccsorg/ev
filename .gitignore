# ============================================================
# Rust / Cargo
# ============================================================
target
debug

# Backup files from rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc
**/*.pdb

# Generated by cargo mutants
**/mutants.out*/

**/*_llms

# ============================================================
# Logs and temporary files
# ============================================================
**/*.log
**/*.bak
**/*.backup

# ============================================================
# Python
# ============================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.ipynb_checkpoints/

# ============================================================
# Quarto (docs)
# ============================================================
**/*_cached*
**/*quarto_ipynb*
/docs/**/*_files
/docs/**/*_output
/docs/**/*_extensions 
/docs/**/*_libs
/docs/**/*.tex
/docs/**/*.pdf
/docs/**/*.html
/docs/**/*.c2pa_identifier.svg

# Global Quarto
**/*.quarto_ipynb
**/*.quarto
**/*_site

# ============================================================
# C2PA
# ============================================================
**/*.c2pa

# ============================================================
# Configuration directories
# ============================================================
**/.*
!/.vscode/
!/.github/
!**/.devcontainer/
!**/.dockerignore

# ============================================================
# docs/build.py
# ============================================================
_docsbuild/
_agent/
_pages/
_jupyter_cache/
