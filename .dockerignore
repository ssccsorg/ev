# ---1. Version Control & CI/CD ---
# Exclude unnecessary metadata and workflow for Docker builds
.git/
.gitmodules
.gitattributes
.github/workflows/

# ---2. Documentation source files (not needed for image build) ---
# Exclude documentation source files to preserve cache when only docs change
docs/**/*.py
docs/**/*.qmd
docs/**/*.md
docs/**/*.yml
docs/**/*.yaml
docs/**/*.json
docs/**/*.txt
docs/**/*.svg
docs/**/*.bib
docs/**/*.csl
docs/**/*.c2pa_manifest.json
# Keep Dockerfile and required config files
!docs/Dockerfile
!docs/requirements.txt
!docs/tex-packages.txt

# ---3. Python Artifacts (based on build.py) ---
# Cache and binary files generated by the Python interpreter
**/__pycache__/
**/*.py[cod]
**/*.pyd
**/$py.class
**/*.egg-info/
**/.eggs/
**/dist/
**/build/
**/*.so

# ---3. Quarto Generated Artifacts (Core) ---
# Linked with IGNORING_ARTIFACT_PATTERNS in build.py
# Files on the host are ignored since they are recreated inside the container
# [Caution] Use docs/prefix (since the build context is root)
docs/**/*_files/
docs/**/*_output/
docs/**/*_extensions/
docs/**/*_cached/
docs/**/*_libs/
docs/**/_site/
**/*.quarto_ipynb
**/*.quarto

# ---4. Rendered Outputs (regeneration target) ---
# Build output is excluded because it is generated inside the container
# These must be excluded so that the cache is maintained when only the source is changed
docs/**/*.tex
docs/**/*.pdf
docs/**/*.html
**/*.c2pa
**/*.c2pa_identifier.svg

# ---5. Build Cache & Temp Files ---
# build.py Temporary directory created by website mode (--website)
quarto_website_*/
/tmp/quarto_*

# General log and backup files
**/*.log
**/*.bak
**/*.backup
**/*.tmp
**/*.swp
**/*.swo
*~

# ---6. Rust/Cargo Artifacts (if included in project) ---
target/
debug/
**/*.rs.bk
**/*.pdb
**/mutants.out*/

# ---7. IDE & Local Config ---
# Developer local settings are separated from the container environment
.idea/
*.sublime-*
*.code-workspace
*.local.yml
*.override.yml
*.env

# ---8. Virtual Environments ---
# Docker uses its own environment, so local virtual environment is excluded.
.venv/
venv/
env/
ENV/

# ---9. OS Metadata ---
.DS_Store
Thumbs.db
ehthumbs.db

# ---10. Docker Self-Reference ---
# Prevent recursive inclusion (optional)
.dockerignore